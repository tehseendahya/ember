# Copy to `.env.local` and fill in values (never commit real secrets).

# Required for AI network ranking and world result formatting
OPENAI_API_KEY=

# Required for "Search the World" (Exa people search)
EXA_API_KEY=

# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sign-in with Google (Supabase Auth) ---
# No extra env vars: enable the Google provider in the Supabase dashboard
# (Authentication > Providers > Google) and paste your Google OAuth Client ID
# and Client Secret there.
#
# In Google Cloud Console, create OAuth client credentials (or reuse a
# project) and add this Authorized redirect URI (replace <project-ref>):
#   https://<project-ref>.supabase.co/auth/v1/callback
#
# In Supabase: Authentication > URL Configuration — set Site URL to your
# app origin (e.g. http://localhost:3000) and add the same origin under
# Redirect URLs, plus:
#   http://localhost:3000/auth/callback
#   https://<your-production-host>/auth/callback
#
# Magic link (email OTP) still uses Supabase email; on the free tier, rate
# limits are tight until you add custom SMTP under Project Settings > Auth.

# Google Calendar OAuth integration (Task 2)
# Create OAuth client credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match OAuth redirect URI configured in Google Cloud Console.
# Local dev example: http://localhost:3000/api/integrations/google-calendar/callback
GOOGLE_REDIRECT_URI=
# Optional: comma-separated scopes override
# GOOGLE_CALENDAR_SCOPES=openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/calendar.readonly
# Set to 1 to log every calendar event and skip reason in the server terminal during sync
# GOOGLE_CALENDAR_SYNC_LOG=1
